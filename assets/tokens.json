    "white":       { "value": "#ffffff" },
    "mist":        { "value": "#f1f1f1", "comment": "alternating section / card fill" },
    "surface-ink": { "value": "#191919", "comment": "footer / dark band" },
    "black":       { "value": "#000000" },
    "hairline":        { "value": "#cacaca" },
