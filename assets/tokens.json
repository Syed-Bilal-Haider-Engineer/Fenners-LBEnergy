    "comment": "Drop into tailwind.config.js theme.extend",
    "colors": {
      "coral": "#ff6148", "ember": "#f24227", "ocean": "#19567b",
      "navy": "#1e4268", "sky": "#0b75b7", "ink": "#191919", "mist": "#f1f1f1"
    },
    "fontFamily": { "sans": ["Barlow", "system-ui", "sans-serif"] }
